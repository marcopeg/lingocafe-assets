# LingoCafe Assets deployment environment.
# Copy this file to .env and fill in real values.

# Required by `make deploy` and `make deploy.nocache`.
CAPROVER_URL=https://captain.example.com
CAPROVER_APP=lingocafe-assets
CAPROVER_APP_TOKEN=replace-with-caprover-app-token

# Optional overrides.
# IMAGE=marcopeg/lingocafe-assets
# VERSION=20260608112243
# UNIVERSAL_PLATFORMS=linux/amd64,linux/arm64
# CAPROVER=npx --yes caprover
# CAPROVER_IMAGE=marcopeg/lingocafe-assets:20260608112243

# Local development overrides.
# PORT=4000
# CONTAINER=lingocafe-assets
# SRC_DIR=/absolute/path/to/src
# NGINX_DEV_CONF=/absolute/path/to/nginx.dev.conf
